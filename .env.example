# ============================================
# Garden College Web — Variables de Entorno
# Copiar a .env y completar con valores reales
# NUNCA commitear .env al repositorio
# ============================================

# --- Base de Datos ---
DB_PASSWORD=cambiar_por_password_seguro_generado_con_openssl

# --- Sitio ---
SITE_URL=https://gardencollege.cl
# En desarrollo: http://localhost:3000

# --- NextAuth ---
# Generar con: openssl rand -base64 32
AUTH_SECRET=cambiar_por_secret_generado

# --- Google OAuth 2.0 ---
# Crear en: https://console.cloud.google.com/apis/credentials
# Tipo: Web application
# Redirect URI: https://gardencollege.cl/api/auth/callback/google
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret

# --- Restricción de acceso al panel admin ---
# Solo emails de este dominio pueden autenticarse
# Dejar vacío para permitir cualquier dominio (NO recomendado en prod)
ALLOWED_EMAIL_DOMAIN=gardenlaunion.cl

# --- Node ---
NODE_ENV=production
