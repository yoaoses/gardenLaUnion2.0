// ============================================
// Garden College Web — Modelo de Datos
// PostgreSQL | Prisma ORM
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================
// AUTH & USUARIOS
// ==================

enum Role {
  ADMIN
  EDITOR
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(EDITOR)
  image     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  noticias Noticia[] @relation("autor")
  galerias Galeria[] @relation("autorGaleria")
}

// ==================
// CONTENIDO PÚBLICO
// ==================

enum NoticiaEstado {
  BORRADOR
  PUBLICADA
  ARCHIVADA
}

model Noticia {
  id               String         @id @default(cuid())
  titulo           String
  slug             String         @unique
  extracto         String
  contenido        String
  imagenPortada    String?
  estado           NoticiaEstado  @default(BORRADOR)
  destacada        Boolean        @default(false)
  fechaPublicacion DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  autorId    String
  autor      User        @relation("autor", fields: [autorId], references: [id])
  categorias Categoria[] @relation("NoticiaCategorias")

  @@index([estado, fechaPublicacion])
  @@index([slug])
}

model Categoria {
  id       String    @id @default(cuid())
  nombre   String    @unique
  slug     String    @unique
  noticias Noticia[] @relation("NoticiaCategorias")
}

// ==================
// GALERÍA
// ==================

model Galeria {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String?
  fecha       DateTime
  visible     Boolean  @default(true)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  autorId String
  autor   User   @relation("autorGaleria", fields: [autorId], references: [id])
  fotos   Foto[]
}

model Foto {
  id        String   @id @default(cuid())
  url       String
  thumbnail String?
  alt       String?
  orden     Int      @default(0)
  createdAt DateTime @default(now())

  galeriaId String
  galeria   Galeria @relation(fields: [galeriaId], references: [id], onDelete: Cascade)
}

// ==================
// INFO INSTITUCIONAL (key-value, SaaS-ready)
// ==================

model ConfigSitio {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     String
  tipo      String   @default("text") // text | richtext | json | image
  grupo     String // institucional | contacto | admision | sellos | redes | convivencia
  orden     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([grupo])
}

// ==================
// CONTACTO
// ==================

model MensajeContacto {
  id        String   @id @default(cuid())
  nombre    String
  email     String
  telefono  String?
  asunto    String
  mensaje   String
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())
}
